# LiteLLM model string — provider/model format
# Examples: openai/gpt-4o-mini, anthropic/claude-sonnet-4-5-20250929, ollama/llama3
LLM_MODEL=openai/gpt-4o-mini

# API key (or set provider-specific env vars like OPENAI_API_KEY, ANTHROPIC_API_KEY)
LLM_API_KEY=your-api-key-here

# Optional: override base URL for local providers (ollama, lmstudio)
# LLM_API_BASE=http://localhost:11434

# The language being learned (e.g. Greek, Spanish, French, Japanese)
TARGET_LANGUAGE=Greek
